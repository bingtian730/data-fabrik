# Copy to .env and adjust for your environment.

# Set to your host user's UID to avoid Airflow file permission issues
# Find with: id -u
AIRFLOW_UID=50000

# Airflow webserver signing key — generate with: openssl rand -hex 32
AIRFLOW_SECRET_KEY=please-change-me

# MinIO root credentials
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# Host port for Postgres (override if 5432 is already in use locally)
POSTGRES_HOST_PORT=5433
