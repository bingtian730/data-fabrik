{
  "$defs": {
    "DbtTransformConfig": {
      "additionalProperties": false,
      "description": "Run dbt models for this pipeline.",
      "properties": {
        "type": {
          "const": "dbt",
          "enum": [
            "dbt"
          ],
          "title": "Type",
          "type": "string"
        },
        "project_dir": {
          "default": "/usr/app/dbt",
          "title": "Project Dir",
          "type": "string"
        },
        "profiles_dir": {
          "default": "/usr/app/dbt",
          "title": "Profiles Dir",
          "type": "string"
        },
        "select": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "dbt --select selector.",
          "title": "Select"
        },
        "target": {
          "default": "dev",
          "title": "Target",
          "type": "string"
        }
      },
      "required": [
        "type"
      ],
      "title": "DbtTransformConfig",
      "type": "object"
    },
    "FreshnessValidation": {
      "additionalProperties": false,
      "description": "Assert a timestamp column has data newer than max_lag_minutes.",
      "properties": {
        "type": {
          "const": "freshness",
          "enum": [
            "freshness"
          ],
          "title": "Type",
          "type": "string"
        },
        "connection_id": {
          "title": "Connection Id",
          "type": "string"
        },
        "table": {
          "title": "Table",
          "type": "string"
        },
        "timestamp_column": {
          "title": "Timestamp Column",
          "type": "string"
        },
        "max_lag_minutes": {
          "default": 1440,
          "exclusiveMinimum": 0,
          "title": "Max Lag Minutes",
          "type": "integer"
        }
      },
      "required": [
        "type",
        "connection_id",
        "table",
        "timestamp_column"
      ],
      "title": "FreshnessValidation",
      "type": "object"
    },
    "HttpApiSourceConfig": {
      "additionalProperties": false,
      "description": "Fetch from an HTTP endpoint and land in the raw bucket.",
      "properties": {
        "type": {
          "const": "http_api",
          "enum": [
            "http_api"
          ],
          "title": "Type",
          "type": "string"
        },
        "url": {
          "title": "Url",
          "type": "string"
        },
        "method": {
          "default": "GET",
          "enum": [
            "GET",
            "POST"
          ],
          "title": "Method",
          "type": "string"
        },
        "headers": {
          "additionalProperties": {
            "type": "string"
          },
          "title": "Headers",
          "type": "object"
        },
        "auth_connection_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Auth Connection Id"
        },
        "dest_bucket": {
          "default": "datafabrik-raw",
          "title": "Dest Bucket",
          "type": "string"
        },
        "dest_key": {
          "title": "Dest Key",
          "type": "string"
        }
      },
      "required": [
        "type",
        "url",
        "dest_key"
      ],
      "title": "HttpApiSourceConfig",
      "type": "object"
    },
    "JdbcSourceConfig": {
      "additionalProperties": false,
      "description": "Pull from a JDBC source via an Airflow connection.",
      "properties": {
        "type": {
          "const": "jdbc",
          "enum": [
            "jdbc"
          ],
          "title": "Type",
          "type": "string"
        },
        "connection_id": {
          "title": "Connection Id",
          "type": "string"
        },
        "query": {
          "title": "Query",
          "type": "string"
        },
        "dest_bucket": {
          "default": "datafabrik-raw",
          "title": "Dest Bucket",
          "type": "string"
        },
        "dest_key": {
          "title": "Dest Key",
          "type": "string"
        }
      },
      "required": [
        "type",
        "connection_id",
        "query",
        "dest_key"
      ],
      "title": "JdbcSourceConfig",
      "type": "object"
    },
    "PipelineStages": {
      "additionalProperties": false,
      "description": "The four stages of a DataFabrik pipeline.\n\n- `ingestion` is required (every pipeline has a source).\n- `transformation` and `delivery` are optional; a missing stage is\n  rendered as an EmptyOperator in the DAG so downstream stages still\n  depend on its completion.\n- `validation` is a list \u2014 each rule runs in parallel after\n  transformation and gates the delivery stage.",
      "properties": {
        "ingestion": {
          "discriminator": {
            "mapping": {
              "http_api": "#/$defs/HttpApiSourceConfig",
              "jdbc": "#/$defs/JdbcSourceConfig",
              "s3_csv": "#/$defs/S3CsvSourceConfig"
            },
            "propertyName": "type"
          },
          "oneOf": [
            {
              "$ref": "#/$defs/S3CsvSourceConfig"
            },
            {
              "$ref": "#/$defs/HttpApiSourceConfig"
            },
            {
              "$ref": "#/$defs/JdbcSourceConfig"
            }
          ],
          "title": "Ingestion"
        },
        "transformation": {
          "anyOf": [
            {
              "discriminator": {
                "mapping": {
                  "dbt": "#/$defs/DbtTransformConfig",
                  "spark": "#/$defs/SparkTransformConfig",
                  "sql": "#/$defs/SqlTransformConfig"
                },
                "propertyName": "type"
              },
              "oneOf": [
                {
                  "$ref": "#/$defs/DbtTransformConfig"
                },
                {
                  "$ref": "#/$defs/SqlTransformConfig"
                },
                {
                  "$ref": "#/$defs/SparkTransformConfig"
                }
              ]
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Transformation"
        },
        "validation": {
          "items": {
            "discriminator": {
              "mapping": {
                "freshness": "#/$defs/FreshnessValidation",
                "row_count": "#/$defs/RowCountValidation",
                "schema": "#/$defs/SchemaValidation"
              },
              "propertyName": "type"
            },
            "oneOf": [
              {
                "$ref": "#/$defs/RowCountValidation"
              },
              {
                "$ref": "#/$defs/SchemaValidation"
              },
              {
                "$ref": "#/$defs/FreshnessValidation"
              }
            ]
          },
          "title": "Validation",
          "type": "array"
        },
        "delivery": {
          "anyOf": [
            {
              "discriminator": {
                "mapping": {
                  "s3_publish": "#/$defs/S3PublishDestinationConfig",
                  "slack_notify": "#/$defs/SlackNotifyDestinationConfig",
                  "webhook": "#/$defs/WebhookDestinationConfig"
                },
                "propertyName": "type"
              },
              "oneOf": [
                {
                  "$ref": "#/$defs/S3PublishDestinationConfig"
                },
                {
                  "$ref": "#/$defs/SlackNotifyDestinationConfig"
                },
                {
                  "$ref": "#/$defs/WebhookDestinationConfig"
                }
              ]
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Delivery"
        }
      },
      "required": [
        "ingestion"
      ],
      "title": "PipelineStages",
      "type": "object"
    },
    "RowCountValidation": {
      "additionalProperties": false,
      "description": "Assert a table has a row count within [min_rows, max_rows].",
      "properties": {
        "type": {
          "const": "row_count",
          "enum": [
            "row_count"
          ],
          "title": "Type",
          "type": "string"
        },
        "connection_id": {
          "title": "Connection Id",
          "type": "string"
        },
        "table": {
          "title": "Table",
          "type": "string"
        },
        "min_rows": {
          "default": 1,
          "minimum": 0,
          "title": "Min Rows",
          "type": "integer"
        },
        "max_rows": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Max Rows"
        }
      },
      "required": [
        "type",
        "connection_id",
        "table"
      ],
      "title": "RowCountValidation",
      "type": "object"
    },
    "S3CsvSourceConfig": {
      "additionalProperties": false,
      "description": "Copy CSV files from a source S3 location to the raw bucket.",
      "properties": {
        "type": {
          "const": "s3_csv",
          "enum": [
            "s3_csv"
          ],
          "title": "Type",
          "type": "string"
        },
        "source_bucket": {
          "title": "Source Bucket",
          "type": "string"
        },
        "source_key": {
          "description": "Object key, supports glob (e.g. 'daily/*.csv').",
          "title": "Source Key",
          "type": "string"
        },
        "dest_bucket": {
          "default": "datafabrik-raw",
          "title": "Dest Bucket",
          "type": "string"
        },
        "dest_prefix": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Dest Prefix"
        }
      },
      "required": [
        "type",
        "source_bucket",
        "source_key"
      ],
      "title": "S3CsvSourceConfig",
      "type": "object"
    },
    "S3PublishDestinationConfig": {
      "additionalProperties": false,
      "description": "Copy curated data to a downstream-readable S3 location.",
      "properties": {
        "type": {
          "const": "s3_publish",
          "enum": [
            "s3_publish"
          ],
          "title": "Type",
          "type": "string"
        },
        "source_bucket": {
          "default": "datafabrik-curated",
          "title": "Source Bucket",
          "type": "string"
        },
        "source_prefix": {
          "title": "Source Prefix",
          "type": "string"
        },
        "dest_bucket": {
          "title": "Dest Bucket",
          "type": "string"
        },
        "dest_prefix": {
          "title": "Dest Prefix",
          "type": "string"
        }
      },
      "required": [
        "type",
        "source_prefix",
        "dest_bucket",
        "dest_prefix"
      ],
      "title": "S3PublishDestinationConfig",
      "type": "object"
    },
    "ScheduleConfig": {
      "additionalProperties": false,
      "description": "When and how a pipeline runs.\n\nSpecify exactly one of `cron` or `preset` (or omit both for an\nunscheduled DAG that only runs on manual trigger).",
      "properties": {
        "cron": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Standard 5-field cron expression, e.g. '0 6 * * *'.",
          "title": "Cron"
        },
        "preset": {
          "anyOf": [
            {
              "enum": [
                "@hourly",
                "@daily",
                "@weekly",
                "@monthly",
                "@yearly",
                "@once"
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Airflow preset shortcut.",
          "title": "Preset"
        },
        "start_date": {
          "description": "Earliest logical date for a DAG run.",
          "format": "date-time",
          "title": "Start Date",
          "type": "string"
        },
        "end_date": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Stop scheduling new runs after this date.",
          "title": "End Date"
        },
        "timezone": {
          "default": "UTC",
          "title": "Timezone",
          "type": "string"
        },
        "catchup": {
          "default": false,
          "description": "Backfill missed runs between start_date and now.",
          "title": "Catchup",
          "type": "boolean"
        },
        "max_active_runs": {
          "default": 1,
          "minimum": 1,
          "title": "Max Active Runs",
          "type": "integer"
        },
        "retries": {
          "default": 3,
          "minimum": 0,
          "title": "Retries",
          "type": "integer"
        },
        "retry_delay_minutes": {
          "default": 5,
          "minimum": 0,
          "title": "Retry Delay Minutes",
          "type": "integer"
        }
      },
      "title": "ScheduleConfig",
      "type": "object"
    },
    "SchemaValidation": {
      "additionalProperties": false,
      "description": "Assert a table's columns exactly match an expected list.",
      "properties": {
        "type": {
          "const": "schema",
          "enum": [
            "schema"
          ],
          "title": "Type",
          "type": "string"
        },
        "connection_id": {
          "title": "Connection Id",
          "type": "string"
        },
        "table": {
          "title": "Table",
          "type": "string"
        },
        "expected_columns": {
          "items": {
            "type": "string"
          },
          "minItems": 1,
          "title": "Expected Columns",
          "type": "array"
        }
      },
      "required": [
        "type",
        "connection_id",
        "table",
        "expected_columns"
      ],
      "title": "SchemaValidation",
      "type": "object"
    },
    "SlackNotifyDestinationConfig": {
      "additionalProperties": false,
      "description": "Post a completion notification to a Slack channel.",
      "properties": {
        "type": {
          "const": "slack_notify",
          "enum": [
            "slack_notify"
          ],
          "title": "Type",
          "type": "string"
        },
        "connection_id": {
          "default": "slack_default",
          "title": "Connection Id",
          "type": "string"
        },
        "channel": {
          "title": "Channel",
          "type": "string"
        },
        "message": {
          "description": "Supports Jinja templating.",
          "title": "Message",
          "type": "string"
        }
      },
      "required": [
        "type",
        "channel",
        "message"
      ],
      "title": "SlackNotifyDestinationConfig",
      "type": "object"
    },
    "SparkTransformConfig": {
      "additionalProperties": false,
      "description": "Submit a Spark job (e.g. to an EMR cluster).",
      "properties": {
        "type": {
          "const": "spark",
          "enum": [
            "spark"
          ],
          "title": "Type",
          "type": "string"
        },
        "cluster_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Cluster Id"
        },
        "script": {
          "title": "Script",
          "type": "string"
        },
        "arguments": {
          "items": {
            "type": "string"
          },
          "title": "Arguments",
          "type": "array"
        }
      },
      "required": [
        "type",
        "script"
      ],
      "title": "SparkTransformConfig",
      "type": "object"
    },
    "SqlTransformConfig": {
      "additionalProperties": false,
      "description": "Execute a SQL script against a configured connection.",
      "properties": {
        "type": {
          "const": "sql",
          "enum": [
            "sql"
          ],
          "title": "Type",
          "type": "string"
        },
        "connection_id": {
          "title": "Connection Id",
          "type": "string"
        },
        "sql_file": {
          "title": "Sql File",
          "type": "string"
        },
        "parameters": {
          "title": "Parameters",
          "type": "object"
        }
      },
      "required": [
        "type",
        "connection_id",
        "sql_file"
      ],
      "title": "SqlTransformConfig",
      "type": "object"
    },
    "WebhookDestinationConfig": {
      "additionalProperties": false,
      "description": "Call an HTTP webhook to notify a downstream system.",
      "properties": {
        "type": {
          "const": "webhook",
          "enum": [
            "webhook"
          ],
          "title": "Type",
          "type": "string"
        },
        "url": {
          "title": "Url",
          "type": "string"
        },
        "method": {
          "default": "POST",
          "enum": [
            "POST",
            "PUT"
          ],
          "title": "Method",
          "type": "string"
        },
        "headers": {
          "additionalProperties": {
            "type": "string"
          },
          "title": "Headers",
          "type": "object"
        },
        "payload": {
          "title": "Payload",
          "type": "object"
        }
      },
      "required": [
        "type",
        "url"
      ],
      "title": "WebhookDestinationConfig",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "description": "Customer pipeline schema.\n\nA pipeline YAML is loaded with `PipelineConfig.from_yaml(path)`. The\nfactory then builds an Airflow DAG by wiring the four stages in\norder: ingestion -> transformation -> [validation rules] -> delivery.",
  "properties": {
    "pipeline_id": {
      "description": "Unique identifier; also used as the Airflow DAG id.",
      "title": "Pipeline Id",
      "type": "string"
    },
    "description": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Description"
    },
    "owner": {
      "default": "data-platform",
      "title": "Owner",
      "type": "string"
    },
    "tags": {
      "items": {
        "type": "string"
      },
      "title": "Tags",
      "type": "array"
    },
    "default_args": {
      "title": "Default Args",
      "type": "object"
    },
    "schedule": {
      "$ref": "#/$defs/ScheduleConfig"
    },
    "stages": {
      "$ref": "#/$defs/PipelineStages"
    }
  },
  "required": [
    "pipeline_id",
    "stages"
  ],
  "title": "PipelineConfig",
  "type": "object",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://datafabrik.dev/schemas/pipeline_config.schema.json"
}
